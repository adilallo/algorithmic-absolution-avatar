# Kiosk proxy secrets & knobs (ALG-8 TTS + ALG-15 absolution). Copy this file to `.env` (same
# folder) and set the keys. `.env` is gitignored — keys must NEVER be committed or served to the
# browser.

# Google Cloud Text-to-Speech API key. Restrict it to the Text-to-Speech API in the
# Cloud Console and set a billing budget/quota as a backstop.
GOOGLE_TTS_API_KEY=

# Optional overrides (defaults shown):
# PORT=8765
# HOST=127.0.0.1
# TTS_ENDPOINT=https://eu-texttospeech.googleapis.com/v1beta1/text:synthesize
# TTS_ALLOWED_VOICES=en-GB-Standard-A,en-GB-Standard-B,en-GB-Standard-C,en-GB-Standard-D
# TTS_ALLOWED_LANGS=en-GB,en-US
# TTS_MAX_INPUT_CHARS=2000
# TTS_DAILY_CHAR_CAP=200000           # daily Google-TTS char budget (resets UTC midnight). The long
#                                     # 1800-char reads burn it ~3-4x faster; still a real billing
#                                     # guard — tune to your Google free tier for production.

# --- Absolution / LLM (ALG-15) ---------------------------------------------------------------
# Magisterium AI API key. Lives ONLY here (server-side, gitignored); never reaches the browser.
# Without it, /absolution serves canned fallback text only (the kiosk still runs).
MAGISTERIUM_API_KEY=

# Optional overrides (defaults shown). Endpoint/model are overridable so the exact path can be
# corrected from here without a code change if the API differs from the assumed OpenAI-compatible
# shape (POST chat/completions, Bearer auth, model magisterium-1).
# MAGISTERIUM_API_URL=https://www.magisterium.com/api/v1/chat/completions
# MAGISTERIUM_MODEL=magisterium-1
# ABSOLUTION_TIMEOUT_MS=60000         # latency backstop. Magisterium runs ~25-40s (30-37k RAG tokens);
#                                     # 30s sat on the boundary -> ~half of real calls aborted as
#                                     # "timeouts" and fell back to canned. 60s lets them complete.
# ABSOLUTION_MAX_TOKENS=320           # trims the visible answer only; does NOT cap RAG/system tokens
# ABSOLUTION_TEMPERATURE=0.4          # the model authors the absolution from the declared harms;
#                                     # keep low for modest variation. For a gallery, prefer
#                                     # pre-baking/caching per punch-tuple (docs/ABSOLUTION_PROMPT.md).
# ABSOLUTION_MAX_SPOKEN_CHARS=1800    # hard cap on spoken text; must stay under TTS_MAX_INPUT_CHARS
#                                     # (2000) or TTS 400s -> silence. To read the full ~4-5k-char
#                                     # answer, raise TTS_MAX_INPUT_CHARS above it too.
# ABSOLUTION_DAILY_REQUEST_CAP=300    # free-tier / billing backstop; counts successful calls only
# ABSOLUTION_MAX_INFLIGHT=2           # concurrent /absolution requests
